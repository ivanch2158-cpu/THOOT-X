# ═════════════════════════════════════════════════════════════════════════════
# SUPABASE — Base de Datos, Autenticación y Storage
# ═════════════════════════════════════════════════════════════════════════════

# URL de tu proyecto Supabase (obtén en https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clave anónima de Supabase (pública, segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Clave de servicio de Supabase (SECRETO — solo en el servidor)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# URL directa a PostgreSQL (para Prisma)
DATABASE_URL=postgresql://user:password@host:port/database

# URL directa sin libpq (fallback para algunas conexiones)
DIRECT_URL=postgresql://user:password@host:port/database


# ═════════════════════════════════════════════════════════════════════════════
# EMAILS — Resend
# ═════════════════════════════════════════════════════════════════════════════

# Clave API de Resend (para envío de emails transaccionales)
RESEND_API_KEY=re_your-api-key-here


# ═════════════════════════════════════════════════════════════════════════════
# WHATSAPP — Meta Cloud API
# ═════════════════════════════════════════════════════════════════════════════

# Token de acceso a WhatsApp Cloud API (Meta oficial)
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id

# Token permanente para la API
WHATSAPP_API_TOKEN=your-api-token-here

# Número de teléfono del consultorio (formato: +51999888777)
WHATSAPP_BUSINESS_PHONE=+51999888777


# ═════════════════════════════════════════════════════════════════════════════
# APLICACIÓN
# ═════════════════════════════════════════════════════════════════════════════

# Entorno (development | production | staging)
NODE_ENV=development

# URL base de la aplicación (para links en emails, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secreto para firmar cookies y tokens internos
SESSION_SECRET=your-secure-random-secret-min-32-characters

# Duración de sesión (en horas)
SESSION_DURATION_HOURS=14
